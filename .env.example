PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/proxy_api
AWS_REGION=eu-west-2
KMS_KEY_ID=alias/proxy-api
ADMIN_PASSWORD=replace-with-strong-shared-password
