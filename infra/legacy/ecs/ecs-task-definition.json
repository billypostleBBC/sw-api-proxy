{
  "family": "proxy-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/proxyApiTaskRole",
  "containerDefinitions": [
    {
      "name": "proxy-api",
      "image": "<account-id>.dkr.ecr.eu-west-2.amazonaws.com/proxy-api:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 3000, "protocol": "tcp" }],
      "environment": [
        { "name": "PORT", "value": "3000" },
        { "name": "AWS_REGION", "value": "eu-west-2" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/proxy-api/DATABASE_URL" },
        { "name": "KMS_KEY_ID", "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/proxy-api/KMS_KEY_ID" },
        { "name": "SES_FROM_EMAIL", "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/proxy-api/SES_FROM_EMAIL" },
        { "name": "APP_BASE_URL", "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/proxy-api/APP_BASE_URL" },
        { "name": "SESSION_SIGNING_KEY", "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/proxy-api/SESSION_SIGNING_KEY" },
        { "name": "CLIENT_TICKET_SIGNING_KEY", "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/proxy-api/CLIENT_TICKET_SIGNING_KEY" },
        { "name": "ADMIN_EMAIL_ALLOWLIST", "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/proxy-api/ADMIN_EMAIL_ALLOWLIST" },
        { "name": "CORS_ALLOWED_ORIGINS", "valueFrom": "arn:aws:ssm:eu-west-2:<account-id>:parameter/proxy-api/CORS_ALLOWED_ORIGINS" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/proxy-api",
          "awslogs-region": "eu-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
