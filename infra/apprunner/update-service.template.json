{
  "ServiceArn": "arn:aws:apprunner:eu-west-2:445816555466:service/proxy-api/<service-id>",
  "SourceConfiguration": {
    "ImageRepository": {
      "ImageIdentifier": "445816555466.dkr.ecr.eu-west-2.amazonaws.com/proxy-api:20260310-5e75be7",
      "ImageRepositoryType": "ECR",
      "ImageConfiguration": {
        "Port": "3000",
        "RuntimeEnvironmentVariables": {
          "AWS_REGION": "eu-west-2"
        },
        "RuntimeEnvironmentSecrets": {
          "DATABASE_URL": "/proxy-api/DATABASE_URL",
          "KMS_KEY_ID": "/proxy-api/KMS_KEY_ID",
          "ADMIN_PASSWORD": "/proxy-api/ADMIN_PASSWORD",
          "ADMIN_EMAIL_ALLOWLIST": "/proxy-api/ADMIN_EMAIL_ALLOWLIST",
          "CORS_ALLOWED_ORIGINS": "/proxy-api/CORS_ALLOWED_ORIGINS"
        }
      }
    },
    "AutoDeploymentsEnabled": false,
    "AuthenticationConfiguration": {
      "AccessRoleArn": "arn:aws:iam::445816555466:role/proxy-api-apprunner-ecr-access-role"
    }
  },
  "InstanceConfiguration": {
    "Cpu": "1024",
    "Memory": "2048",
    "InstanceRoleArn": "arn:aws:iam::445816555466:role/proxy-api-apprunner-instance-role"
  },
  "HealthCheckConfiguration": {
    "Protocol": "HTTP",
    "Path": "/health",
    "Interval": 10,
    "Timeout": 5,
    "HealthyThreshold": 1,
    "UnhealthyThreshold": 5
  },
  "NetworkConfiguration": {
    "IngressConfiguration": {
      "IsPubliclyAccessible": true
    },
    "EgressConfiguration": {
      "EgressType": "VPC",
      "VpcConnectorArn": "arn:aws:apprunner:eu-west-2:445816555466:vpcconnector/proxy-api-vpc-connector/1/1226dce53f4646298d53cb10723fafce"
    },
    "IpAddressType": "IPV4"
  }
}
